\@writefile{toc}{\contentsline {subsection}{7.1.1 Roadmap, with destinations labelled}{342}{section*.469}\protected@file@percent }
\newlabel{roadmap-with-destinations-labelled}{{}{342}{7.1.1 Roadmap, with destinations labelled}{section*.469}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {153}{\ignorespaces Roadmap. The CRR tree decomposes into per-step log-return increments \(X_i\) taking values \(\pm \mitsigma \sqrt  {\mitDelta t}\). By the CLT (Ch 0 §0.10), \(\sum X_i\) becomes normal as \(n\to \infty \). The terminal distribution of \(\log (S_T/S_0)\) is therefore \(N(\mitmu _*T, \mitsigma ^2 T)\) with \(\mitmu _* = r-\mitsigma ^2/2\). From there, \(\mitPhi (d_1)\) and \(\mitPhi (d_2)\) pop out and the BS formula is assembled.}}{342}{figure.0.153}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{7.1.2 First, just compute the destination}{342}{section*.470}\protected@file@percent }
