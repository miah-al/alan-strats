\@writefile{lof}{\contentsline {figure}{\numberline {80}{\ignorespaces Three bar charts side by side: leaf masses on \(\mitOmega _2\) under real-world \(\symbb P\) (\(p=0.6\)), under risk-neutral \(\tilde {\symbb P}\) (\(\tilde p=0.5\)), and the leaf-wise ratio \(Z = \tilde {\symbb P}/\symbb P\). The first two redistribute mass across the same four leaves; the third reads off the redistribution per leaf.}}{173}{figure.0.80}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{3.11.3 Table}{173}{section*.273}\protected@file@percent }
